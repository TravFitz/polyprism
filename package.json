{
  "name": "polyprism",
  "private": true,
  "version": "0.0.0",
  "description": "Multi-pattern Prisma type generator. Pick your output (interface, type, class, domain-class, zod, ...) via one config knob.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "author": "Travis Fitzgerald",
  "homepage": "https://github.com/TravFitz/polyprism",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TravFitz/polyprism.git"
  },
  "bugs": {
    "url": "https://github.com/TravFitz/polyprism/issues"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r --parallel test:watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "ci": "biome ci .",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "node scripts/guard-release.mjs && pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@changesets/cli": "^2.27.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^3.2.6",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
