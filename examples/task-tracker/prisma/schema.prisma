// Task-tracker example.
// A mid-weight Kanban-style schema designed to showcase the things that make
// the **class** pattern distinct from interface/type aliases:
//
//   - Class fields get *real initializer expressions*, so you can write
//     `new Task({ ... })` without filling in every field manually.
//   - `cuid()` / `now()` / `autoincrement()` defaults — values Prisma assigns
//     at insert time — emit as `field!: Type` (definite-assignment) because
//     there's no stable TS literal to put there.
//   - Literal defaults that map cleanly to TS (`Int`, `Float`, `String`,
//     `Boolean`, enum values) emit as `field: Type = literal;`.
//   - Enum-value defaults trigger OmniPrism's mixed type/value import
//     handling: the import line becomes `import { type X, EnumName }` so the
//     `EnumName.VALUE` reference resolves at runtime.
//   - Nullable scalars without a default initialize to `null`.
//   - Lists always initialize to `[]` (Prisma never returns null for lists).
//
// Pattern: `omniprism-ts-class`.

generator omniprismCodegen {
  provider  = "omniprism-ts-class"
  output    = "../generated"
  emitIndex = "true"
}

datasource db {
  provider = "postgresql"
}

// ───────────────────────────────────────────────────────────────────────────
// Enums
// ───────────────────────────────────────────────────────────────────────────

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  /// @deprecated("use Project.archived instead")
  WONT_DO
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Role {
  VIEWER
  CONTRIBUTOR
  MAINTAINER
  OWNER
}

// ───────────────────────────────────────────────────────────────────────────
// Models
// ───────────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  displayName  String
  role         Role      @default(CONTRIBUTOR)
  active       Boolean   @default(true)
  joinedAt     DateTime  @default(now())

  /// Never emitted — @hide drops the field entirely.
  /// @hide
  passwordHash String

  ownedProjects Project[] @relation("ProjectOwner")
  assignedTasks Task[]    @relation("TaskAssignee")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  archived    Boolean  @default(false)
  /// Daily target velocity, in story points.
  velocity    Int      @default(20)
  /// Project accent colour. Demonstrates a String literal default.
  colorHex    String   @default("#6366f1")

  /// Inline-named JSON type — emits to json-types/ProjectSettings.ts and is
  /// imported as `import type { ProjectSettings } from "./json-types/...";`.
  /// @json(ProjectSettings = { notifyOnAssign: boolean, autoCloseAfterDays: number })
  settings    Json?

  ownerId     String
  owner       User     @relation("ProjectOwner", fields: [ownerId], references: [id])

  tasks       Task[]
  createdAt   DateTime @default(now())
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  /// Story points. Int default(0) — emits as `points: number = 0`.
  /// NOT as `Date.parse("0")` (that was the prisma-class-generator bug).
  points      Int        @default(0)
  completed   Boolean    @default(false)
  dueAt       DateTime?

  projectId   String
  project     Project    @relation(fields: [projectId], references: [id])

  assigneeId  String?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])

  /// Lists always default to an empty array in class mode — Prisma never
  /// returns null for a list field.
  tags        String[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
