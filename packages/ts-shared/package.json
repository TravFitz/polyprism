{
  "name": "@polyprism/ts-shared",
  "version": "0.1.0",
  "description": "Shared TypeScript rendering primitives used by PolyPrism's Prisma 6 & 7 generators (ts-interface, ts-type, ts-class). Pure ESM.",
  "type": "module",
  "license": "MIT",
  "author": "Travis Fitzgerald",
  "homepage": "https://github.com/TravFitz/polyprism/tree/main/packages/ts-shared",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TravFitz/polyprism.git",
    "directory": "packages/ts-shared"
  },
  "bugs": {
    "url": "https://github.com/TravFitz/polyprism/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "polyprism-source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "prisma",
    "prisma-generator",
    "prisma-7",
    "typescript",
    "codegen",
    "esm",
    "polyprism"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@polyprism/core": "workspace:*"
  }
}
