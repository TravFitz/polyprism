{
  "name": "@polyprism/ts-domain-class",
  "version": "0.1.6",
  "description": "Prisma 6 & 7 generator that emits opinionated TypeScript domain classes — private fields, getters/setters with active @coerce + @normalise, builder, from(), toJSON(). Pure ESM. Part of PolyPrism.",
  "type": "module",
  "license": "MIT",
  "author": "Travis Fitzgerald",
  "homepage": "https://github.com/TravFitz/polyprism/tree/main/packages/ts-domain-class",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TravFitz/polyprism.git",
    "directory": "packages/ts-domain-class"
  },
  "bugs": {
    "url": "https://github.com/TravFitz/polyprism/issues"
  },
  "bin": {
    "polyprism-ts-domain-class": "./dist/generator.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "polyprism-source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "prisma",
    "prisma-generator",
    "prisma-7",
    "typescript",
    "domain-class",
    "domain-driven-design",
    "codegen",
    "esm",
    "polyprism"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@polyprism/core": "workspace:*",
    "@polyprism/ts-shared": "workspace:*"
  },
  "devDependencies": {
    "@polyprism/runtime": "workspace:*",
    "@prisma/client": "^6.19.3"
  }
}
