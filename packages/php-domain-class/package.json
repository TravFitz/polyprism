{
  "name": "@polyprism/php-domain-class",
  "version": "0.3.1",
  "description": "Prisma 6 & 7 generator that emits PHP 8.4 domain classes with property hooks — @coerce / @normalise honoured via the polyprism/runtime Composer package. Pure ESM. Part of PolyPrism.",
  "type": "module",
  "license": "MIT",
  "author": "Travis Fitzgerald",
  "homepage": "https://github.com/TravFitz/polyprism/tree/main/packages/php-domain-class",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TravFitz/polyprism.git",
    "directory": "packages/php-domain-class"
  },
  "bugs": {
    "url": "https://github.com/TravFitz/polyprism/issues"
  },
  "bin": {
    "polyprism-php-domain-class": "./dist/generator.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "polyprism-source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "prisma",
    "prisma-generator",
    "prisma-7",
    "php",
    "php-8",
    "php-8.4",
    "property-hooks",
    "domain-class",
    "coerce",
    "codegen",
    "esm",
    "polyprism"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@polyprism/core": "workspace:*",
    "@polyprism/php-shared": "workspace:*"
  }
}
