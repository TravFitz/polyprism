{
  "name": "@polyprism/runtime",
  "version": "0.3.1",
  "description": "Runtime helpers (normalise + coerce primitives) used by @polyprism/ts-domain-class. The TypeScript-side runtime — only required when you choose the opinionated domain-class pattern. PHP users want the polyprism/runtime Composer package instead. ESM-first with a CJS sibling for legacy test runners, zero third-party runtime deps.",
  "type": "module",
  "license": "MIT",
  "author": "Travis Fitzgerald",
  "homepage": "https://github.com/TravFitz/polyprism/tree/main/packages/runtime",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TravFitz/polyprism.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/TravFitz/polyprism/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "polyprism-source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "prisma",
    "prisma-7",
    "polyprism",
    "runtime",
    "coerce",
    "normalise",
    "esm",
    "cjs"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  }
}
