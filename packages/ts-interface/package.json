{
  "name": "@polyprism/ts-interface",
  "version": "0.1.1",
  "description": "Prisma 6 & 7 generator that emits TypeScript interfaces (`export interface User { ... }`) from your schema. Pure ESM, zero runtime deps, configurable naming + annotations. Part of PolyPrism.",
  "type": "module",
  "license": "MIT",
  "author": "Travis Fitzgerald",
  "homepage": "https://github.com/TravFitz/polyprism/tree/main/packages/ts-interface",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TravFitz/polyprism.git",
    "directory": "packages/ts-interface"
  },
  "bugs": {
    "url": "https://github.com/TravFitz/polyprism/issues"
  },
  "bin": {
    "polyprism-ts-interface": "./dist/generator.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "polyprism-source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "prisma",
    "prisma-generator",
    "prisma-7",
    "typescript",
    "interface",
    "codegen",
    "esm",
    "polyprism"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@polyprism/core": "workspace:*",
    "@polyprism/ts-shared": "workspace:*"
  }
}
